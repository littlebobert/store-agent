    "start": "node dist/server.js",
    "db:migrate": "tsx src/migrate.ts"
  },
  "dependencies": {
    "@azure/service-bus": "^7.9.5",
    "@slack/bolt": "^4.6.0",
    "@slack/types": "^2.20.1",
    "@store-agent/core": "workspace:*",
    "@store-agent/providers": "workspace:*",
    "dotenv": "^17.3.1",
    "zod": "^4.3.6"
  }
}
