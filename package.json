{
  "name": "store-agent",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm exec eslint \"apps/**/*.ts\" \"packages/**/*.ts\"",
    "dev:api": "pnpm --filter @store-agent/api dev",
    "dev:worker": "pnpm --filter @store-agent/worker dev",
    "db:migrate": "pnpm --filter @store-agent/api db:migrate"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.5.0",
    "@types/pg": "^8.18.0",
    "eslint": "^10.0.3",
    "globals": "^17.4.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.1"
  }
}
